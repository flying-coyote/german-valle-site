---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Photography" description="Stills and frame grabs by German Valle.">
  <div class="pt-32 md:pt-40 pb-12 mx-auto max-w-[1600px] px-6 md:px-10">
    <p class="smallcaps text-xs text-[color:var(--color-accent-400)] mb-3">Photography</p>
    <h1 class="font-serif text-5xl md:text-7xl text-[color:var(--color-text-display)] tracking-tight mb-4">
      Stills.
    </h1>
    <p class="text-[color:var(--color-text-muted)] max-w-2xl">
      Frame grabs and on-set stills, organized by project. Coming soon.
    </p>
  </div>

  <!-- Placeholder grid — replace with real frame grabs in Session 3 -->
  <section class="mx-auto max-w-[1600px] px-6 md:px-10 pb-32">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-4">
      {Array.from({ length: 9 }).map((_, i) => (
        <div class="aspect-[3/2] bg-[color:var(--color-bg-elevated)] flex items-center justify-center">
          <span class="smallcaps text-xs text-[color:var(--color-text-faint)]">Still {i + 1}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
