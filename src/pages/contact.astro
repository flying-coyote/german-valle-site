---
import Layout from "../layouts/Layout.astro";
import { AGENT_NAME, AGENT_AGENCY, AGENT_EMAIL, CONTACT_EMAIL, SITE_NAME } from "../config.ts";
---

<Layout title="Contact" description={`Contact ${SITE_NAME} for cinematography inquiries.`}>
  <div class="pt-32 md:pt-40 pb-32 mx-auto max-w-[1000px] px-6 md:px-10">
    <p class="smallcaps text-xs text-[color:var(--color-accent-400)] mb-3">Contact</p>
    <h1 class="font-serif text-5xl md:text-7xl text-[color:var(--color-text-display)] tracking-tight mb-16">
      Get in touch.
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20">
      <div>
        <p class="smallcaps text-xs text-[color:var(--color-text-muted)] mb-4">Representation</p>
        <p class="font-serif text-2xl text-[color:var(--color-text-display)] mb-2">{AGENT_NAME}</p>
        <p class="text-[color:var(--color-text-muted)] mb-1">{AGENT_AGENCY}</p>
        <a href={`mailto:${AGENT_EMAIL}`} class="text-[color:var(--color-text-primary)] hover:text-[color:var(--color-accent-400)]">
          {AGENT_EMAIL}
        </a>
      </div>

      <div>
        <p class="smallcaps text-xs text-[color:var(--color-text-muted)] mb-4">Direct</p>
        <p class="text-[color:var(--color-text-muted)] mb-3 leading-relaxed">
          For project inquiries reaching German directly.
        </p>
        <a href={`mailto:${CONTACT_EMAIL}`} class="text-[color:var(--color-text-primary)] hover:text-[color:var(--color-accent-400)]">
          {CONTACT_EMAIL}
        </a>
      </div>
    </div>
  </div>
</Layout>
