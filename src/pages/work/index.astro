---
import Layout from "../../layouts/Layout.astro";
import ProjectTile from "../../components/ProjectTile.astro";
import { projects } from "../../data/projects.ts";

// Group by category in a cinematographer-conventional order.
const order: Array<typeof projects[number]["category"]> = [
  "Feature",
  "Episodic",
  "Commercial",
  "Music Video",
  "Documentary",
  "Short",
];
const grouped = order
  .map((cat) => ({ category: cat, items: projects.filter((p) => p.category === cat) }))
  .filter((g) => g.items.length > 0);
---

<Layout title="Work">
  <div class="pt-32 md:pt-40 pb-12 mx-auto max-w-[1600px] px-6 md:px-10">
    <p class="smallcaps text-xs text-[color:var(--color-accent-400)] mb-3">Work</p>
    <h1 class="font-serif text-5xl md:text-7xl text-[color:var(--color-text-display)] tracking-tight mb-4">
      Selected projects.
    </h1>
    <p class="text-[color:var(--color-text-muted)] max-w-2xl">
      Features, episodic, commercial, and short-form work as Director of Photography.
    </p>
  </div>

  {grouped.map(({ category, items }) => (
    <section class="mx-auto max-w-[1600px] px-6 md:px-10 py-12 md:py-16">
      <h2 class="smallcaps text-sm text-[color:var(--color-text-muted)] mb-8">
        {category}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {items.map((project) => <ProjectTile project={project} />)}
      </div>
    </section>
  ))}
</Layout>
