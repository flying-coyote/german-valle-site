---
import Layout from "../layouts/Layout.astro";
import { SITE_NAME, IMDB_URL } from "../config.ts";
---

<Layout title="About" description={`About ${SITE_NAME}, Director of Photography.`}>
  <div class="pt-32 md:pt-40 pb-24 mx-auto max-w-[1100px] px-6 md:px-10">
    <p class="smallcaps text-xs text-[color:var(--color-accent-400)] mb-3">About</p>
    <h1 class="font-serif text-5xl md:text-7xl text-[color:var(--color-text-display)] tracking-tight mb-12">
      {SITE_NAME}
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-12 md:gap-16">
      <div class="aspect-[3/4] bg-[color:var(--color-bg-elevated)] flex items-center justify-center">
        <span class="smallcaps text-xs text-[color:var(--color-text-faint)]">Headshot · TBD</span>
      </div>

      <div class="prose-cinema">
        <p class="text-xl md:text-2xl text-[color:var(--color-text-display)] font-serif leading-snug mb-8">
          German Valle is a Director of Photography based in Los Angeles.
        </p>

        <p class="text-[color:var(--color-text-muted)] leading-relaxed mb-6">
          Recent credits include cinematography on Tyler Perry's <em>Zatima</em> and <em>House of Payne</em>,
          <em>Young Dylan</em> for Nickelodeon, <em>Curveball</em> on ALLBLK, <em>Sincerely Love</em>
          for In The Black Network, <em>Not My Family: The Monique Smith Story</em> on Lifetime,
          and the 2025 feature <em>Blue Devils</em>.
        </p>

        <p class="text-[color:var(--color-text-muted)] leading-relaxed mb-6">
          Before working as DP, German spent years as a gaffer on studio productions across features
          and episodic television.
        </p>

        <p class="text-[color:var(--color-text-faint)] text-sm italic mb-6">
          [Draft bio — to expand or rewrite. Replace this paragraph.]
        </p>

        <div class="mt-12 pt-8 border-t border-[color:var(--color-border-subtle)]">
          <p class="smallcaps text-xs text-[color:var(--color-text-muted)] mb-3">Credits</p>
          <p class="text-[color:var(--color-text-muted)]">
            Full filmography on{" "}
            <a href={IMDB_URL} target="_blank" rel="noopener" class="text-[color:var(--color-text-primary)] hover:text-[color:var(--color-accent-400)]">
              IMDb ↗
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
