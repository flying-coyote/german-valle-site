---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_NAME, SITE_ROLE } from "../config.ts";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Hide header on full-bleed pages (e.g., the reel hero). */
  transparentHeader?: boolean;
}

const {
  title,
  description = `${SITE_NAME} — ${SITE_ROLE}. Cinematography reel and selected work.`,
  ogImage = "/og-default.jpg",
  transparentHeader = false,
} = Astro.props;

const fullTitle = !title || title === SITE_NAME ? `${SITE_NAME} — ${SITE_ROLE}` : `${title} · ${SITE_NAME}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={SITE_NAME} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <ClientRouter />
  </head>
  <body>
    <Header transparent={transparentHeader} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
