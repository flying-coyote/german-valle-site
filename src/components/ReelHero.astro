---
import { SITE_NAME, SITE_ROLE } from "../config.ts";

interface Props {
  vimeoId: string;
  /** Optional pull-quote / tagline overlay. Kept terse. */
  tagline?: string;
}
const { vimeoId, tagline } = Astro.props;

// Vimeo embed: muted autoplay loop on load; click anywhere to open full-screen with audio.
// Background param disables Vimeo's UI for the ambient first impression.
const ambientSrc = `https://player.vimeo.com/video/${vimeoId}?background=1&autoplay=1&loop=1&muted=1&dnt=1`;
const fullSrc = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&dnt=1`;
---

<section class="relative w-full h-[100svh] overflow-hidden bg-black" data-reel-hero>
  <!-- Ambient muted loop (background) -->
  <iframe
    class="absolute inset-0 w-full h-full pointer-events-none"
    src={ambientSrc}
    allow="autoplay; fullscreen; picture-in-picture"
    title={`${SITE_NAME} — showcase reel`}
    data-ambient-frame
  ></iframe>

  <!-- Subtle vignette so the type stays readable on bright frames -->
  <div class="absolute inset-0 pointer-events-none bg-gradient-to-b from-black/40 via-transparent to-black/70"></div>

  <!-- Wordmark + role -->
  <div class="absolute inset-x-0 bottom-0 px-6 md:px-10 pb-12 md:pb-20 pointer-events-none">
    <div class="max-w-[1600px] mx-auto">
      <p class="smallcaps text-xs md:text-sm text-[color:var(--color-accent-400)] mb-3">
        {tagline ?? "Showcase reel"}
      </p>
      <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl text-white tracking-tight leading-[0.95] mb-3">
        {SITE_NAME}
      </h1>
      <p class="smallcaps text-sm md:text-base text-[color:var(--color-text-muted)]">
        {SITE_ROLE}
      </p>
    </div>
  </div>

  <!-- Play-with-sound button -->
  <button
    type="button"
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 group focus:outline-none"
    data-play-with-sound
    aria-label="Play reel with sound"
  >
    <span class="block h-20 w-20 md:h-28 md:w-28 rounded-full border border-white/40 group-hover:border-[color:var(--color-accent-400)] group-hover:bg-black/30 transition-all flex items-center justify-center">
      <svg class="h-7 w-7 md:h-9 md:w-9 fill-white group-hover:fill-[color:var(--color-accent-400)] transition-colors translate-x-0.5" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M8 5v14l11-7L8 5z"></path>
      </svg>
    </span>
    <span class="block mt-3 smallcaps text-xs text-white/80 group-hover:text-[color:var(--color-accent-400)] transition-colors">
      Play with sound
    </span>
  </button>

  <!-- Full-audio modal (hidden until invoked) -->
  <div
    class="fixed inset-0 z-50 hidden bg-black/95 items-center justify-center p-4 md:p-10"
    data-reel-modal
    aria-hidden="true"
  >
    <button
      type="button"
      class="absolute top-6 right-6 text-white/80 hover:text-[color:var(--color-accent-400)] smallcaps text-xs"
      data-close-modal
      aria-label="Close reel"
    >
      Close ✕
    </button>
    <div class="w-full max-w-6xl aspect-video">
      <iframe
        class="w-full h-full"
        data-full-frame
        data-full-src={fullSrc}
        src="about:blank"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title={`${SITE_NAME} — full reel`}
      ></iframe>
    </div>
  </div>
</section>

<script>
  const playBtn = document.querySelector<HTMLButtonElement>("[data-play-with-sound]");
  const modal = document.querySelector<HTMLDivElement>("[data-reel-modal]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-close-modal]");
  const fullFrame = document.querySelector<HTMLIFrameElement>("[data-full-frame]");

  const open = () => {
    if (!modal || !fullFrame) return;
    const fullSrc = fullFrame.dataset.fullSrc ?? "";
    fullFrame.src = fullSrc;
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  };

  const close = () => {
    if (!modal || !fullFrame) return;
    fullFrame.src = "about:blank";
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  };

  playBtn?.addEventListener("click", open);
  closeBtn?.addEventListener("click", close);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) close();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
  });
</script>
