---
import type { Project } from "../data/projects.ts";
import { parseVideoUrl } from "../utils/video.ts";

interface Props {
  project: Project;
}
const { project } = Astro.props;
const href = `/work/${project.slug}`;
const video = parseVideoUrl(project.videoUrl);
const poster = project.posterImage ?? video.posterUrl;
---

<a href={href} class="group block">
  <div class="relative aspect-[16/10] overflow-hidden bg-[color:var(--color-bg-elevated)]">
    <img
      src={poster}
      alt={project.title}
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover transition-all duration-500 group-hover:scale-[1.03]"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  </div>
  <div class="mt-4 flex items-baseline justify-between gap-4">
    <h3 class="font-serif text-xl md:text-2xl text-[color:var(--color-text-display)] tracking-tight leading-snug">
      {project.title}
    </h3>
    <span class="smallcaps text-[10px] text-[color:var(--color-text-faint)] group-hover:text-[color:var(--color-accent-400)] transition-colors whitespace-nowrap">
      view →
    </span>
  </div>
</a>
