---
import type { Project } from "../data/projects.ts";
import { parseVideoUrl } from "../utils/video.ts";

interface Props {
  project: Project;
}
const { project } = Astro.props;
const href = `/work/${project.slug}`;
const video = parseVideoUrl(project.videoUrl);
const poster = project.posterImage ?? video.posterUrl;
---

<a href={href} class="group block">
  <div class="relative aspect-[16/10] overflow-hidden bg-[color:var(--color-bg-elevated)]">
    <img
      src={poster}
      alt={project.title}
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover transition-all duration-500 group-hover:scale-[1.03] group-hover:opacity-90"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-100"></div>
    <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
      <p class="smallcaps text-xs text-[color:var(--color-accent-400)] mb-1">
        {project.category} · {project.year}
      </p>
      <h3 class="font-serif text-2xl md:text-3xl text-white tracking-tight leading-tight">
        {project.title}
      </h3>
      {project.director && (
        <p class="text-sm text-[color:var(--color-text-muted)] mt-1">
          dir. {project.director}
        </p>
      )}
    </div>
  </div>
</a>
